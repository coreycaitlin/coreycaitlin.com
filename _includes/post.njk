---
layout: layout.njk
tags: post
permalink: "/writing/{{ page.fileSlug }}/"
---

<div class="post-header">
  <h1 class="post-title">{{ title }}</h1>
  {% if subtitle %}<p class="post-subtitle">{{ subtitle }}</p>{% endif %}
  <p class="post-meta">{{ date | date('MMMM D, YYYY') }}{% if meta %} | {{ meta }}{% endif %}</p>
</div>
<div class="post-body">
  {{ content | safe }}
</div>
<div class="post-back">
  <a href="/writing/">« Back to writing archive</a>
</div>
