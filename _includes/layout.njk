<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/main.css">
  <title>{{ title }}</title>
</head>
<body>
  <header>
    <h1>Corey Mahoney</h1>
    <nav>
      <ul>
      {%- for nav in collections.nav -%}
        <li{% if page.url == nav.url %} aria-current="page"{% endif %}>
          <a href="{{ nav.url }}">{{ nav.data.title }}</a>
        </li>
      {%- endfor -%}
      </ul>
    </nav>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    &copy; 2022 Corey Mahoney
    <a href="/checklists/">checklists</a>
    /
    <a href="/hey/">reminders</a>
  </footer>
</body>
</html>
